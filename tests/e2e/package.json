{
  "name": "matrimony-e2e-tests",
  "version": "1.0.0",
  "description": "Selenium E2E tests for Matrimony project",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "mocha --recursive --timeout 60000 --exit",
    "test:chrome": "cross-env BROWSER=chrome mocha --recursive --timeout 60000 --exit",
    "test:firefox": "cross-env BROWSER=firefox mocha --recursive --timeout 60000 --exit",
    "test:headless": "cross-env HEADLESS=true mocha --recursive --timeout 60000 --exit",
    "test:report": "cross-env HEADLESS=true mocha --recursive --timeout 60000 --exit --reporter mochawesome --reporter-options reportDir=reports,reportFilename=e2e-report",
    "test:ci": "cross-env HEADLESS=true CI=true mocha --recursive --timeout 90000 --exit --reporter mochawesome --reporter-options reportDir=reports,reportFilename=ci-report"
  },
  "dependencies": {
    "selenium-webdriver": "^4.20.0",
    "mocha": "^10.4.0",
    "chai": "^5.1.1",
    "dotenv": "^16.4.5",
    "mochawesome": "^7.1.3",
    "cross-env": "^7.0.3"
  }
}
